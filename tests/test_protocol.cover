    6: class ProtocolTests(unittest.TestCase):
    3:     def test_encode_decode_input(self):
    3:         frame = Frame(session="s1", role="client", type=FrameType.INPUT.value, data=b"ls\n")
    3:         raw = encode(frame)
    3:         decoded = decode(raw)
    3:         self.assertEqual(decoded.type, FrameType.INPUT.value)
    3:         self.assertEqual(decoded.data, b"ls\n")
       
    3:     def test_encode_decode_output(self):
    3:         frame = Frame(session="s1", role="client", type=FrameType.OUTPUT.value, data=b"ok")
    3:         raw = encode(frame)
    3:         decoded = decode(raw)
    3:         self.assertEqual(decoded.type, FrameType.OUTPUT.value)
    3:         self.assertEqual(decoded.data, b"ok")
       
    3:     def test_encode_decode_status(self):
    3:         frame = Frame(session="s1", role="browser", type=FrameType.STATUS.value, data=b'{"peers":0}')
    3:         raw = encode(frame)
    3:         decoded = decode(raw)
    3:         self.assertEqual(decoded.type, FrameType.STATUS.value)
    3:         self.assertEqual(decoded.data, b'{"peers":0}')
       
    3:     def test_invalid_frame_type(self):
    3:         raw = encode(Frame(session="s1", role="client", type="stdin", data=b"bad"))
    6:         with self.assertRaises(ProtocolError):
    3:             decode(raw)
       
    3:     def test_fuzz_decode_invalid(self):
