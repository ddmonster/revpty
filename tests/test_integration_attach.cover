    3: import asyncio
    3: import unittest
       
    3: from aiohttp import web, ClientSession, WSMsgType
       
    3: from revpty.server.app import websocket_handler, on_startup, on_cleanup
    3: from revpty.protocol.codec import encode, decode
    3: from revpty.protocol.frame import Frame, FrameType
       
       
    6: class IntegrationAttachTests(unittest.IsolatedAsyncioTestCase):
    3:     async def asyncSetUp(self):
    3:         self.app = web.Application()
    3:         self.app.on_startup.append(on_startup)
    3:         self.app.on_cleanup.append(on_cleanup)
    3:         self.app.router.add_get("/", websocket_handler)
    3:         self.runner = web.AppRunner(self.app)
    3:         await self.runner.setup()
    3:         self.site = web.TCPSite(self.runner, "127.0.0.1", 0)
    3:         await self.site.start()
    3:         sockets = self.site._server.sockets
    3:         self.port = sockets[0].getsockname()[1]
       
    3:     async def asyncTearDown(self):
    6:         await self.runner.cleanup()
       
    3:     async def test_attach_receives_status(self):
    3:         url = f"ws://127.0.0.1:{self.port}/"
    6:         async with ClientSession() as session:
    6:             async with session.ws_connect(url) as ws:
    6:                 await ws.send_str(encode(Frame(
    3:                     session="s1",
    3:                     role="browser",
    3:                     type=FrameType.ATTACH.value,
                       )))
    3:                 msg = await ws.receive(timeout=2)
    3:                 self.assertEqual(msg.type, WSMsgType.TEXT)
    3:                 frame = decode(msg.data)
    3:                 self.assertEqual(frame.type, FrameType.STATUS.value)
